# npm 镜像源配置（加速 npm 包下载）
registry=https://registry.npmmirror.com

# Puppeteer 配置
# 跳过 Chromium 下载（如果系统已安装 Chrome/Chromium）
# 通过环境变量设置：export PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Puppeteer Chromium 下载镜像源（如果仍需要下载）
# 通过环境变量设置：export PUPPETEER_DOWNLOAD_HOST=https://npmmirror.com/mirrors
# 注意：puppeteer_download_host 在 .npmrc 中已废弃，请使用环境变量

# 可选：设置 Chromium 下载路径
# puppeteer_cache_dir=~/.cache/puppeteer

